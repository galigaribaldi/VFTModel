# VFT Model — Variables de Entorno
# Copiar este archivo y renombrarlo según el entorno:
#   cp .env.example .env.local   → desarrollo local (apimetro en localhost)
#   cp .env.example .env.dev     → entorno DEV (apimetro.dev)

# URL base del backend Go (APIMETRO).
# Incluye el prefijo de ruta /movilidad — NO agregar barra al final.
#
# LOCAL:  http://localhost:8080/movilidad
# DEV:    https://apimetro.dev/movilidad
APIMETRO_URL=http://localhost:8080/movilidad
